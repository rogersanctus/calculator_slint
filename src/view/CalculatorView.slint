import io.slint.*

export type CalculatorApp {
    // No properties needed; UI will call methods directly
}

CalculatorApp {
    Box {
        width: 400px
        height: 500px
        padding: 10px
        background: "#f0f0f0"

        // Display
        Text {
            id: display_text
            width: 100%
            text: app.display()
            font-size: 32px
            horizontal-align: center
            padding: 10px
        }

        Grid {
            columns: 4
            rows: 5
            width: 100%
            height: 100%
            spacing: 5px

            // Row 1: 7 8 9 /
            Button { text: "7"; on_click: app.inputDigit(7); on_click: display_text.set_text(app.display()); }
            Button { text: "8"; on_click: app.inputDigit(8); on_click: display_text.set_text(app.display()); }
            Button { text: "9"; on_click: app.inputDigit(9); on_click: display_text.set_text(app.display()); }
            Button { text: "/"; on_click: app.inputOperation('/'); on_click: display_text.set_text(app.display()); }

            // Row 2: 4 5 6 *
            Button { text: "4"; on_click: app.inputDigit(4); on_click: display_text.set_text(app.display()); }
            Button { text: "5"; on_click: app.inputDigit(5); on_click: display_text.set_text(app.display()); }
            Button { text: "6"; on_click: app.inputDigit(6); on_click: display_text.set_text(app.display()); }
            Button { text: "*"; on_click: app.inputOperation('*'); on_click: display_text.set_text(app.display()); }

            // Row 3: 1 2 3 -
            Button { text: "1"; on_click: app.inputDigit(1); on_click: display_text.set_text(app.display()); }
            Button { text: "2"; on_click: app.inputDigit(2); on_click: display_text.set_text(app.display()); }
            Button { text: "3"; on_click: app.inputDigit(3); on_click: display_text.set_text(app.display()); }
            Button { text: "-"; on_click: app.inputOperation('-'); on_click: display_text.set_text(app.display()); }

            // Row 4: 0 % = +
            Button { text: "0"; on_click: app.inputDigit(0); on_click: display_text.set_text(app.display()); }
            Button { text: "%"; on_click: app.inputOperation('%'); on_click: display_text.set_text(app.display()); }
            Button { text: "="; on_click: app.inputEquals(); on_click: display_text.set_text(app.display()); }
            Button { text: "+"; on_click: app.inputOperation('+'); on_click: display_text.set_text(app.display()); }

            // Row 5: Clear and Eraser spanning two columns each
            Button { text: "C"; width: 100%; on_click: app.clear(); on_click: display_text.set_text(app.display()); }
            Button { text: "←"; width: 100%; on_click: app.erase(); on_click: display_text.set_text(app.display()); }
        }
    }
}
